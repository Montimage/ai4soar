# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_DEBUG=false

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=ai4soar

# NATS messaging broker
NATS_HOST=localhost
NATS_PORT=4222

# Kafka messaging broker
KAFKA_BROKERS=localhost:9093
KAFKA_SSL_PASSWORD=

# LLM (openai)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
LLM_CONFIDENCE_THRESHOLD=0.70

# ML model (options: knn | lr | ovr_lr | ovr_svm | rf | mlp)
SIMILARITY_MODEL=mlp

# Orchestration tuning (optional — defaults shown)
# ORCH_EARLY_EXIT_THRESHOLD=0.85
# ORCH_LOW_CONF_THRESHOLD=0.50
# ORCH_PATH_C_DISCOUNT=0.85
# ORCH_CONFIRMATION_BONUS=0.10

# Playbook library
# PLAYBOOK_LIBRARY_PATH=playbooks